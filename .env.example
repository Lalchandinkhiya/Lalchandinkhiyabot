# ══════════════════════════════════════════════════
#   LALCHAND INKHIYA BOT — .env Configuration
#   Copy this file:  cp .env.example .env
#   Then fill in your real values below
# ══════════════════════════════════════════════════

# ── REQUIRED (Bot won't start without these) ──────
BOT_TOKEN=7123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPER_ADMIN_ID=123456789
MONGODB_URI=mongodb://localhost:27017
SECRET_KEY=change_this_to_any_random_32_char_string_abc

# ── OPTIONAL ──────────────────────────────────────
# Extra admins (comma-separated Telegram IDs)
ADMIN_IDS=

DB_NAME=lalchand_inkhiya_db
LOG_LEVEL=INFO
FLOOD_RATE=30
SESSION_TIMEOUT=3600
MAX_LOGIN_ATTEMPTS=5
MAX_FILE_SIZE_MB=50
BACKUP_INTERVAL_HOURS=24
AD_ROTATION_INTERVAL=5
MAINTENANCE_MODE=false
FORCE_SUBSCRIBE=false
FORCE_SUBSCRIBE_CHANNEL=
LOG_CHANNEL_ID=
BITLY_TOKEN=
BOT_USERNAME=LalchandInkhiyaBot
